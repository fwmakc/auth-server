NODE_ENV=development
IP=localhost
PORT=3001
ROOT_PATH=.

DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_server
DB_USER=root
DB_PASSWORD=1234
DB_SYNCHRONIZE=true
DB_LOG=true

# RS256 keys: if paths omitted, keys auto-generated in memory (dev only)
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
JWT_CLIENTS_EXPIRES=
JWT_EXPIRES=true

SESSION_SECRET=session_secret_here
SESSION_EXPIRES=2592000

AES_SECRET=change_me_to_32_characters__

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
SMTP_SENDER_NAME=
SMTP_SENDER_EMAIL=

OAUTH_SERVER=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_CLIENT_REDIRECT=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_REDIRECT=

LEADER_CLIENT_ID=
LEADER_CLIENT_SECRET=
LEADER_CLIENT_REDIRECT=

UNTI_CLIENT_ID=
UNTI_CLIENT_SECRET=
UNTI_CLIENT_REDIRECT=

FORM_LOGIN=
FORM_REGISTER=
FORM_RESET=

SWAGGER_PREFIX=swagger
SWAGGER_PREFIX_REDOC=redoc
SWAGGER_TITLE=Auth Server API
SWAGGER_DESCRIPTION=OAuth2 Authorization Server
SWAGGER_VERSION=1.0
